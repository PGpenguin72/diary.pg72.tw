{
  "name": "diary-pg72-tw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run typecheck && vite build",
    "check": "pnpm run typecheck && pnpm run lint",
    "typecheck": "wrangler types && tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "rm -rf .wrangler/e2e-state && pnpm run db:migrate:e2e && pnpm run db:seed:e2e && playwright test",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply diary-pg72-tw-db --local",
    "db:seed:local": "wrangler d1 execute diary-pg72-tw-db --local --file=seed.sql",
    "db:migrate:e2e": "wrangler d1 migrations apply diary-pg72-tw-db --local --persist-to .wrangler/e2e-state",
    "db:seed:e2e": "wrangler d1 execute diary-pg72-tw-db --local --persist-to .wrangler/e2e-state --file=seed.sql"
  },
  "dependencies": {
    "@zip.js/zip.js": "2.8.30",
    "hono": "4.12.30",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@cloudflare/workers-types": "5.20260715.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
