# Local manual login against the real PG72 ID SSO (optional).
# Copy to .dev.vars, then open http://127.0.0.1:5173/api/auth/login after `pnpm dev`.
# Without .dev.vars localhost keeps its normal no-login dev bypass.

# Local public client registered on sso.pg72.tw (no client secret needed).
AUTH_CLIENT_ID=pg72-diary-dev

# Owner OIDC sub. Already set in wrangler.jsonc; to look it up again, query the
# SSO user table: wrangler d1 execute PG72_ID_DB --remote --command "SELECT id FROM user"
#AUTH_ALLOWED_SUBJECT=

# Only for the production confidential client (never commit the real value).
#AUTH_CLIENT_SECRET=
